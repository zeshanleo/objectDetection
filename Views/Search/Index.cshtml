@using VideoDetectionPOC.ViewModel
@model DetectionSearchViewModel

<h2 class="mb-4">🎯 Video Intelligence Search</h2>

<form asp-action="Index" method="post">

    <div class="card p-3 mb-4 shadow-sm">

        <div class="row">

            <div class="col-md-3">
                <label>Objects</label>
                <select asp-for="SelectedObjectTypeIds"
                        asp-items="Model.ObjectTypes"
                        multiple
                        class="form-control">
                </select>
            </div>

            <div class="col-md-2">
                <label>Min Confidence</label>
                <input asp-for="MinConfidence"
                       type="number"
                       step="0.01"
                       class="form-control" />
            </div>

            <div class="col-md-3">
                <label>Video Name</label>
                <input asp-for="VideoName"
                       class="form-control" />
            </div>

            <div class="col-md-2">
                <label>From Date</label>
                <input asp-for="FromDate"
                       type="date"
                       class="form-control" />
            </div>

            <div class="col-md-2">
                <label>To Date</label>
                <input asp-for="ToDate"
                       type="date"
                       class="form-control" />
            </div>

        </div>

        <div class="row mt-3">

            <div class="col-md-3">
                <button type="submit"
                        class="btn btn-primary w-100">
                    🔍 Search
                </button>
            </div>

        </div>

    </div>

</form>


@if (Model.Results != null && Model.Results.Any())
{
    <!-- Summary Card -->
    <div class="card mb-3 bg-light shadow-sm">
        <div class="card-body">
            <h5 class="card-title">Search Summary</h5>
            <p class="mb-1">
                <strong>@Model.Results.Count</strong> Videos Found
            </p>
            <p class="mb-1">
                <strong>@Model.Results.Sum(x => x.TotalDetections)</strong> Total Detections
            </p>
            <p class="mb-0">
                <strong>@Model.Results.Sum(x => x.DistinctObjects)</strong> Distinct Object Types
            </p>
        </div>
    </div>

    <!-- Results Table -->
    <div class="card shadow-sm">
        <div class="card-body">

            <table class="table table-bordered table-hover table-striped">

                <thead class="table-dark">
                    <tr>
                        <th>Video</th>
                        <th>Upload Date</th>
                        <th>Total Detections</th>
                        <th>Distinct Objects</th>
                        <th>Avg Confidence</th>
                        <th>Max Confidence</th>
                        <th></th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model.Results)
                    {
                        <tr>
                            <td>@item.VideoName</td>
                            <td>@item.UploadDate.ToShortDateString()</td>
                            <td>@item.TotalDetections</td>
                            <td>@item.DistinctObjects</td>
                            <td>@item.AvgConfidence.ToString("0.00")</td>
                            <td>@item.MaxConfidence.ToString("0.00")</td>
                            <td>
                                <a asp-action="Details"
                                   asp-route-id="@item.VideoId"
                                   class="btn btn-sm btn-info">
                                    View Timeline
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>
}
else if (Model.Results != null)
{
    <div class="alert alert-warning">
        No results found for the selected criteria.
    </div>
}